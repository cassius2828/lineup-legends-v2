# ==================================
# Lineup Legends v2 - Environment Variables
# ==================================
# Copy this file to .env and fill in the values.

# ---- Authentication ----
AUTH_SECRET="generate-with-npx-auth-secret"
AUTH_GOOGLE_CLIENT_ID=""
AUTH_GOOGLE_CLIENT_SECRET=""

# ---- Database ----
MONGODB_URI="mongodb://localhost:27017/lineup-legends"

# ---- AWS S3 (profile/banner image uploads) ----
AWS_REGION="us-west-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
BUCKET_NAME=""

# ---- Email (Resend) ----
RESEND_API_KEY=""

# ---- Redis (caching) ----
REDIS_URL="redis://localhost:6379"

# ---- YouTube Data API ----
YOUTUBE_API_KEY=""

# ---- OpenAI (AI awards fallback when Wikipedia parsing misses) ----
OPENAI_API_KEY=""

# ---- MFA ----
# 32-byte hex key (64 chars) for encrypting TOTP secrets at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MFA_ENCRYPTION_KEY=""

# ---- Public (exposed to client bundle) ----
NEXT_PUBLIC_CLOUDFRONT_URL=""
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_GIPHY_API_KEY=""

# Stripe Payment Link for "Buy Me a Coffee" (create at https://dashboard.stripe.com/payment-links)
NEXT_PUBLIC_STRIPE_COFFEE_URL=
